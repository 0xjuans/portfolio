---
import "../styles/components/Projects.css";
import { portfolioConfig } from "../config/portfolio.template";
---

<section class="projects-section" id="projects">
	<div class="projects-header">
		<div>
			<p class="eyebrow">Builds</p>
			<h2 data-i18n-es={portfolioConfig.projectsSectionTitle} data-i18n-en={portfolioConfig.english.projectsSectionTitle}>
				{portfolioConfig.projectsSectionTitle}
			</h2>
		</div>
		<div
			class="projects-carousel-controls"
			aria-label="Controles del carrusel de proyectos"
			data-i18n-attr="aria-label"
			data-i18n-es="Controles del carrusel de proyectos"
			data-i18n-en={portfolioConfig.english.projectsControlsLabel}
		>
			<button
				class="projects-carousel-button"
				type="button"
				data-projects-prev
				aria-label="Proyecto anterior"
				data-i18n-attr="aria-label"
				data-i18n-es="Proyecto anterior"
				data-i18n-en={portfolioConfig.english.previousProjectLabel}
			>
				<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</button>
			<button
				class="projects-carousel-button"
				type="button"
				data-projects-next
				aria-label="Proyecto siguiente"
				data-i18n-attr="aria-label"
				data-i18n-es="Proyecto siguiente"
				data-i18n-en={portfolioConfig.english.nextProjectLabel}
			>
				<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</button>
		</div>
	</div>

	<div
		class="projects-carousel"
		aria-roledescription="carrusel"
		aria-label="Proyectos destacados"
		data-i18n-attr="aria-label"
		data-i18n-es="Proyectos destacados"
		data-i18n-en={portfolioConfig.english.projectsCarouselLabel}
	>
		<div class="projects-track" data-projects-viewport tabindex="0">
			{
					portfolioConfig.projects.map((project, projectIndex) => {
						const sourceUrl = "sourceUrl" in project && typeof project.sourceUrl === "string" ? project.sourceUrl : undefined;
						const usesLivePreview = "previewMode" in project && project.previewMode === "iframe";

						return (
							<article
								class="project-card"
								data-project-card
								aria-label={`${project.name}, proyecto ${projectIndex + 1} de ${portfolioConfig.projects.length}`}
								data-i18n-attr="aria-label"
								data-i18n-es={`${project.name}, proyecto ${projectIndex + 1} de ${portfolioConfig.projects.length}`}
								data-i18n-en={`${project.name}, project ${projectIndex + 1} of ${portfolioConfig.projects.length}`}
							>
								<figure class:list={["project-media", usesLivePreview && "project-media-live"]}>
									<img
										src={project.imageUrl}
										alt={`Vista previa del proyecto ${project.name}`}
										loading="lazy"
										data-i18n-attr="alt"
										data-i18n-es={`Vista previa del proyecto ${project.name}`}
										data-i18n-en={`${portfolioConfig.english.projectPreviewAltPrefix} ${project.name}`}
									/>
									{usesLivePreview && (
										<iframe
											class="project-live-preview"
											src={project.projectUrl}
											title={`Preview en vivo de ${project.name}`}
											loading="lazy"
											sandbox="allow-scripts allow-same-origin"
											data-i18n-attr="title"
											data-i18n-es={`Preview en vivo de ${project.name}`}
											data-i18n-en={`${portfolioConfig.english.livePreviewTitlePrefix} ${project.name}`}
										></iframe>
									)}
									{"highlight" in project && project.highlight && <figcaption>{project.highlight}</figcaption>}
								</figure>
								<div class="project-aura" aria-hidden="true"></div>
								<div class="project-body">
									<div class="project-content">
										<div class="project-kicker">
											{"highlight" in project && project.highlight && <p class="project-highlight">{project.highlight}</p>}
											<span
												data-i18n-es={`Proyecto ${String(projectIndex + 1).padStart(2, "0")}`}
												data-i18n-en={`${portfolioConfig.english.projectOrdinalLabel} ${String(projectIndex + 1).padStart(2, "0")}`}
											>
												Proyecto {String(projectIndex + 1).padStart(2, "0")}
											</span>
										</div>
										<h3>
											<a href={project.projectUrl} target="_blank" rel="noopener noreferrer">
												{project.name}
											</a>
										</h3>
										<p
											class="project-description"
											data-i18n-es={project.description}
											data-i18n-en={portfolioConfig.english.projects[projectIndex].description}
										>
											{project.description}
										</p>
										<div class="project-stack">
											{project.stack.map((technology) => <span>{technology}</span>)}
										</div>
									</div>
									<div class="project-links">
										<a href={project.projectUrl} target="_blank" rel="noopener noreferrer" class="project-link live-link">
											<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
												<path
													d="M14 5H19V10M10 14L19 5M18 13V18C18 18.5304 17.7893 19.0391 17.4142 19.4142C17.0391 19.7893 16.5304 20 16 20H6C5.46957 20 4.96086 19.7893 4.58579 19.4142C4.21071 19.0391 4 18.5304 4 18V8C4 7.46957 4.21071 6.96086 4.58579 6.58579C4.96086 6.21071 5.46957 6 6 6H11"
													stroke="currentColor"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												></path>
											</svg>
											<span data-i18n-es="Ver proyecto" data-i18n-en={portfolioConfig.english.viewProjectLabel}>Ver proyecto</span>
										</a>
										{sourceUrl && (
											<a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="project-link code-link">
												<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
													<path
														d="M8.5 16.5L4 12L8.5 7.5M15.5 7.5L20 12L15.5 16.5M13 5L11 19"
														stroke="currentColor"
														stroke-width="1.8"
														stroke-linecap="round"
														stroke-linejoin="round"
													></path>
												</svg>
												<span data-i18n-es="Código" data-i18n-en={portfolioConfig.english.codeLabel}>Código</span>
											</a>
										)}
									</div>
								</div>
							</article>
						);
					})
			}
		</div>
		<div class="projects-carousel-dots" aria-label="Seleccionar proyecto">
			{
				portfolioConfig.projects.map((project, projectIndex) => (
					<button
						type="button"
						data-project-dot
						aria-label={`Ver ${project.name}`}
						data-i18n-attr="aria-label"
						data-i18n-es={`Ver ${project.name}`}
						data-i18n-en={`${portfolioConfig.english.viewProjectDotPrefix} ${project.name}`}
					>
						<span>{String(projectIndex + 1).padStart(2, "0")}</span>
					</button>
				))
			}
		</div>
	</div>
</section>

<script>
	import "../scripts/components/projects.js";
</script>
