---
import "../styles/components/Experience.css";
import { portfolioConfig } from "../config/portfolio.template";
---

<section class="experience-section" id="experiencia">
	<div class="experience-header">
		<p class="eyebrow" data-i18n-es="Trayectoria" data-i18n-en={portfolioConfig.english.experienceEyebrow}>Trayectoria</p>
		<h2 data-i18n-es={portfolioConfig.experienceSectionTitle} data-i18n-en={portfolioConfig.english.experienceSectionTitle}>
			{portfolioConfig.experienceSectionTitle}
		</h2>
	</div>

	<div class="timeline">
		<div class="timeline-line" aria-hidden="true"></div>
		{
			portfolioConfig.experiences.map((experience, index) => (
				<article class="experience-card timeline-item">
					<div class="timeline-node" aria-hidden="true">
						<span>{String(index + 1).padStart(2, "0")}</span>
					</div>
					<div class="experience-glow" aria-hidden="true"></div>
					<header>
						<h3 data-i18n-es={experience.role} data-i18n-en={portfolioConfig.english.experiences[index].role}>{experience.role}</h3>
						<p class="meta meta-top">
							<span class="icon-label company-label">
								<span class="meta-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none">
										<path
											d="M4 20V6.8C4 6.36 4.36 6 4.8 6H10V4.8C10 4.36 10.36 4 10.8 4H19.2C19.64 4 20 4.36 20 4.8V20"
											stroke="currentColor"
											stroke-width="1.7"
											stroke-linecap="round"
											stroke-linejoin="round"
										></path>
										<path d="M8 10H8.01M8 14H8.01M12 10H12.01M12 14H12.01M16 10H16.01M16 14H16.01" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
										<path d="M3 20H21" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
									</svg>
								</span>
								{experience.company}
							</span>
							<span class="meta-separator" aria-hidden="true">•</span>
							<span class="meta-pill" data-i18n-es={experience.workMode} data-i18n-en={portfolioConfig.english.experiences[index].workMode}>
								{experience.workMode}
							</span>
						</p>
						<p class="meta meta-bottom">
							<span class="icon-label">
								<span class="meta-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none">
										<path
											d="M12 21C15.6 17.4 18 14.5 18 11.2C18 7.78 15.31 5 12 5C8.69 5 6 7.78 6 11.2C6 14.5 8.4 17.4 12 21Z"
											stroke="currentColor"
											stroke-width="1.7"
											stroke-linecap="round"
											stroke-linejoin="round"
										></path>
										<circle cx="12" cy="11" r="2.2" stroke="currentColor" stroke-width="1.7"></circle>
									</svg>
								</span>
								<span data-i18n-es={experience.location} data-i18n-en={portfolioConfig.english.experiences[index].location}>
									{experience.location}
								</span>
							</span>
							<span class="meta-separator" aria-hidden="true">•</span>
							<span class="icon-label">
								<span class="meta-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none">
										<rect x="4" y="6" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.7"></rect>
										<path d="M8 4V8M16 4V8M4 11H20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
									</svg>
								</span>
								<span data-i18n-es={experience.dateRange} data-i18n-en={portfolioConfig.english.experiences[index].dateRange}>
									{experience.dateRange}
								</span>
							</span>
						</p>
					</header>
					<ul>
						{
							experience.achievements.map((achievement, achievementIndex) => (
								<li>
									<span class="achievement-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none">
											<path d="M9 8L5 12L9 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
											<path d="M15 8L19 12L15 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
										</svg>
									</span>
									<span
										data-i18n-es={achievement}
										data-i18n-en={portfolioConfig.english.experiences[index].achievements[achievementIndex]}
									>
										{achievement}
									</span>
								</li>
							))
						}
					</ul>
				</article>
			))
		}
	</div>
</section>

<script>
	import "../scripts/components/experience.js";
</script>
